---
import Layout from '../layouts/Layout.astro';

const whatsappUrl = 'https://chat.whatsapp.com/InT9jLwLvHcHz3KuTmDrSo';

const topics = [
  ['Developer', 'Bahas web, backend, tooling, deploy, debug, dan praktik kerja harian developer.'],
  ['AI & Automation', 'Belajar pakai AI untuk riset, coding, konten, workflow, dan eksperimen produk.'],
  ['Vibe Coding', 'Ngulik ide cepat, prototyping, prompt, agent coding, dan shipping project kecil.'],
  ['Config 9 Router', 'Diskusi setup router, jaringan rumah/kantor kecil, troubleshooting, dan optimasi koneksi.'],
];

const rules = [
  'Diskusi santai tapi tetap teknis',
  'Boleh tanya dari nol, asal mau mencoba',
  'Share hasil eksperimen, error, config, dan resource',
];
---

<Layout>
  <main id="page-shell" class="relative min-h-screen overflow-hidden text-text-primary">
    <div id="mesh-bg" class="mesh-bg" aria-hidden="true"></div>
    <div class="content-layer">
    <nav class="sticky top-0 z-50 border-b border-border-warm/70 bg-surface-bright/85 backdrop-blur">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href="/" class="flex items-center gap-3 font-semibold" aria-label="9router.id">
          <img src="/9router_logo.webp" alt="Logo 9router.id" class="size-10 rounded-xl object-cover shadow-[0_4px_12px_rgba(2,132,199,0.25)]" width="40" height="40" />
          <span>9router.id</span>
        </a>
        <div class="hidden items-center gap-8 text-sm font-semibold text-text-secondary md:flex">
          <a href="#topik" class="hover:text-terracotta">Topik</a>
          <a href="#cara" class="hover:text-terracotta">Cara Gabung</a>
          <a href="#gabung" class="hover:text-terracotta">WhatsApp</a>
        </div>
        <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="rounded-lg bg-terracotta px-5 py-2.5 text-sm font-semibold text-white! transition hover:bg-burnt-sienna hover:shadow-[0_4px_12px_rgba(155,47,0,0.25)]">Gabung WA</a>
      </div>
    </nav>

    <section class="relative mx-auto grid max-w-6xl gap-12 px-6 py-20 md:grid-cols-[1.05fr_0.95fr] md:items-center md:py-28">
      <div>
        <p class="mb-5 inline-flex rounded-full border border-border-warm bg-surface px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-terracotta">Komunitas WhatsApp Indonesia</p>
        <h1 class="font-display text-5xl font-bold leading-[1.05] tracking-[-0.02em] text-text-primary md:text-7xl">Ngobrol developer, AI, vibe coding, dan 9 router di satu grup WA.</h1>
        <p class="mt-6 max-w-xl text-xl leading-8 text-text-secondary">9router.id adalah tempat diskusi santai untuk orang yang mau belajar teknologi praktis: coding, AI tools, automasi, jaringan, dan konfigurasi router.</p>
        <div class="mt-9 flex flex-col gap-3 sm:flex-row">
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="rounded-lg bg-terracotta px-6 py-3 text-center font-semibold text-white! transition hover:bg-burnt-sienna hover:shadow-[0_4px_12px_rgba(155,47,0,0.25)]">Gabung Grup WhatsApp</a>
          <a href="#topik" class="rounded-lg border border-border-warm px-6 py-3 text-center font-semibold text-text-primary transition hover:bg-surface">Lihat Topik</a>
        </div>
        <dl class="mt-10 grid max-w-xl grid-cols-3 gap-4">
          <div><dt class="font-display text-3xl font-bold">WA</dt><dd class="text-sm text-text-secondary">Grup utama</dd></div>
          <div><dt class="font-display text-3xl font-bold">4+</dt><dd class="text-sm text-text-secondary">Topik diskusi</dd></div>
          <div><dt class="font-display text-3xl font-bold">ID</dt><dd class="text-sm text-text-secondary">Se-Indonesia</dd></div>
        </dl>
      </div>

      <div class="rounded-3xl border border-border-warm bg-surface p-4 shadow-[0_24px_48px_rgba(28,25,23,0.10)]">
        <div class="rounded-2xl bg-warm-white p-5">
          <div class="mb-5 flex items-center justify-between">
            <div><p class="text-sm text-text-secondary">Preview obrolan</p><h2 class="font-display text-3xl font-bold">9router.id WA</h2></div>
            <span class="rounded-full bg-[#16A34A] px-3 py-1 text-sm font-semibold text-white!">Online</span>
          </div>
          <div class="space-y-4">
            {['Ada yang pakai AI agent buat refactor project Astro?', 'Config router buat failover ISP paling stabil gimana?', 'Share prompt vibe coding buat landing page dong.'].map((item, index) => (
              <article class="rounded-xl border border-border-warm bg-surface p-4 transition hover:-translate-y-0.5 hover:shadow-[0_4px_16px_rgba(28,25,23,0.06)]">
                <div class="mb-2 flex items-center justify-between gap-4">
                  <h3 class="font-semibold">Member #{index + 1}</h3>
                  <span class="text-sm text-text-secondary">baru</span>
                </div>
                <p class="text-text-secondary">{item}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="topik" class="mx-auto max-w-6xl px-6 py-16">
      <div class="max-w-2xl"><p class="font-semibold uppercase tracking-[0.16em] text-terracotta">Topik diskusi</p><h2 class="mt-3 font-display text-4xl font-bold md:text-5xl">Bukan kelas formal. Ini ruang ngobrol dan praktik.</h2></div>
      <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {topics.map(([title, body]) => (
          <article class="rounded-xl border border-border-warm bg-surface p-6 transition hover:-translate-y-1 hover:shadow-[0_4px_16px_rgba(28,25,23,0.06)]">
            <div class="mb-5 size-10 rounded-lg bg-surface-container"></div>
            <h3 class="font-display text-2xl font-bold">{title}</h3>
            <p class="mt-3 text-text-secondary">{body}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="cara" class="bg-surface px-6 py-16">
      <div class="mx-auto grid max-w-6xl gap-10 md:grid-cols-[0.9fr_1.1fr] md:items-center">
        <div><p class="font-semibold uppercase tracking-[0.16em] text-terracotta">Cara kerja grup</p><h2 class="mt-3 font-display text-4xl font-bold md:text-5xl">Masuk, kenalan, lalu mulai tanya atau share.</h2></div>
        <div class="grid gap-4">
          {rules.map((rule, index) => (
            <div class="flex gap-4 rounded-xl border border-border-warm bg-surface-bright p-5">
              <span class="grid size-9 shrink-0 place-items-center rounded-full bg-terracotta text-sm font-bold text-white!">{index + 1}</span>
              <p class="font-semibold text-text-primary">{rule}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="gabung" class="mx-auto max-w-4xl px-6 py-20 text-center">
      <p class="font-semibold uppercase tracking-[0.16em] text-terracotta">Gabung sekarang</p>
      <h2 class="mt-3 font-display text-4xl font-bold md:text-5xl">Mau ikut diskusi di WhatsApp?</h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-text-secondary">Klik tombol di bawah untuk langsung masuk ke grup WhatsApp 9router.id.</p>
      <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="mt-8 inline-flex rounded-lg bg-terracotta px-8 py-4 font-semibold text-white! transition hover:bg-burnt-sienna hover:shadow-[0_4px_12px_rgba(155,47,0,0.25)]">Masuk Grup WhatsApp</a>
      <p class="mt-4 text-sm text-text-secondary">WA: 081393558430 · Email: info@9router.id</p>
    </section>

    <footer class="px-6 pb-8 text-center">
      <a href="https://appverse.id" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-full border border-border-warm bg-surface-bright/80 px-4 py-2 text-sm font-semibold text-text-secondary shadow-[0_4px_16px_rgba(15,23,42,0.06)] backdrop-blur transition hover:border-terracotta hover:text-terracotta">
        <span class="size-2 rounded-full bg-terracotta"></span>
        Managed by Appverse.id
      </a>
    </footer>
    </div>
  </main>
  <script>
    const shell = document.getElementById('page-shell');
    const mesh = document.getElementById('mesh-bg');

    shell?.addEventListener('pointermove', (event) => {
      if (!mesh) return;
      mesh.style.setProperty('--ripple-x', `${event.clientX}px`);
      mesh.style.setProperty('--ripple-y', `${event.clientY}px`);
      mesh.style.setProperty('--ripple-scale', '1');
      mesh.style.setProperty('--ripple-opacity', '1');
    });

    shell?.addEventListener('pointerleave', () => {
      if (!mesh) return;
      mesh.style.setProperty('--ripple-scale', '0.45');
      mesh.style.setProperty('--ripple-opacity', '0');
    });
  </script>
</Layout>
